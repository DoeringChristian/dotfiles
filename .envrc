# pixi global needs our local npm build backend (ext/pixi-build-npm) when it
# (re)builds gemini-cli / claude-code. sync.sh and update.sh set this themselves;
# this is just so manual `pixi global sync`/`update` in this dir also works.
export PIXI_BUILD_BACKEND_OVERRIDE="pixi-build-npm=$PWD/ext/pixi-build-npm/pixi-build-npm"
