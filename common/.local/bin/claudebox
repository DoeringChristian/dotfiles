#!/usr/bin/env bash
set -euo pipefail

OS="$(uname -s)"

usage() {
    echo "Usage: claudebox [OPTIONS] [PROJECT_DIR] [-- CLAUDE_ARGS...]"
    echo ""
    if [[ "$OS" == "Darwin" ]]; then
        echo "Run Claude Code with --dangerously-skip-permissions inside a Seatbelt sandbox."
    else
        echo "Run Claude Code with --dangerously-skip-permissions inside a Bubblewrap sandbox."
    fi
    echo ""
    echo "Arguments:"
    echo "  PROJECT_DIR          Project directory (default: current directory)"
    echo ""
    echo "Options:"
    echo "  --bash               Launch a bash shell inside the sandbox"
    if [[ "$OS" != "Darwin" ]]; then
        echo "  --bind PATH          Bind extra directory read-write (repeatable)"
        echo "  --ro-bind PATH       Bind extra directory read-only (repeatable)"
        echo "  --share-pid          Share host PID namespace (shows all processes)"
    fi
    echo "  --ssh                Bind ~/.ssh read-only (off by default)"
    echo "  --block-env FILES    Comma-separated .env files to block (default: .env,.env.local,.env.production)"
    echo "  --no-block-env       Don't block any .env files"
    echo "  -h, --help           Show this help"
    echo ""
    echo "Anything after -- is passed directly to claude."
    echo ""
    echo "Examples:"
    echo "  claudebox ~/projects/myapp"
    echo "  claudebox ~/projects/myapp -- 'Review the code'"
    echo "  claudebox --ssh ~/projects/myapp"
    echo "  claudebox  # uses current directory"
}

BIND_SSH=false
SHARE_PID=false
BLOCK_ENV=".env,.env.local,.env.production"
PROJECT_DIR=""
SHELL_MODE=""
EXTRA_BINDS=()
EXTRA_WRITE_PATHS=()
CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
        usage
        exit 0
        ;;
    --bash)
        SHELL_MODE=bash
        shift
        ;;
    --share-pid)
        SHARE_PID=true
        shift
        ;;
    --bind)
        resolved="$(cd "$2" && pwd)"
        EXTRA_BINDS+=("--bind" "$resolved" "$resolved")
        EXTRA_WRITE_PATHS+=("$resolved")
        shift 2
        ;;
    --ro-bind)
        resolved="$(cd "$2" && pwd)"
        EXTRA_BINDS+=("--ro-bind" "$resolved" "$resolved")
        shift 2
        ;;
    --ssh)
        BIND_SSH=true
        shift
        ;;
    --block-env)
        BLOCK_ENV="$2"
        shift 2
        ;;
    --no-block-env)
        BLOCK_ENV=""
        shift
        ;;
    --)
        shift
        CLAUDE_ARGS+=("$@")
        break
        ;;
    *)
        if [[ -z "$PROJECT_DIR" && -d "$1" ]]; then
            PROJECT_DIR="$1"
        else
            # Forward unrecognized args to claude
            CLAUDE_ARGS+=("$1")
        fi
        shift
        ;;
    esac
done

PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"

if [[ ! -d "$PROJECT_DIR" ]]; then
    echo "Error: $PROJECT_DIR is not a directory" >&2
    exit 1
fi

# Search upward from PROJECT_DIR for .claudebox config
find_config() {
    local dir="$1"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.claudebox" ]]; then
            echo "$dir/.claudebox"
            return
        fi
        dir="$(dirname "$dir")"
    done
}

CONFIG_FILE="$(find_config "$PROJECT_DIR")"
if [[ -n "$CONFIG_FILE" ]]; then
    CONFIG_DIR="$(cd "$(dirname "$CONFIG_FILE")" && pwd)"
    current_section=""

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Strip comments and whitespace
        line="${line%%#*}"
        line="${line%%;;*}"
        line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [[ -z "$line" ]] && continue

        # Section header
        if [[ "$line" =~ ^\[(.+)\]$ ]]; then
            current_section="${BASH_REMATCH[1]}"
            continue
        fi

        # Key = value pairs
        if [[ "$line" =~ ^([^=]+)=(.+)$ ]]; then
            key="$(echo "${BASH_REMATCH[1]}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
            value="$(echo "${BASH_REMATCH[2]}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        else
            continue
        fi

        # Expand ~ and $HOME, resolve relative paths against CONFIG_DIR
        expand_path() {
            local p="$1"
            p="${p/#\~/$HOME}"
            p="${p/\$HOME/$HOME}"
            # Resolve relative paths against config file directory
            if [[ "$p" != /* ]]; then
                p="$CONFIG_DIR/$p"
            fi
            echo "$p"
        }

        case "$current_section" in
            mounts)
                local_path="$(expand_path "$value")"
                [[ -e "$local_path" ]] || continue
                local_path="$(cd "$local_path" && pwd)"
                case "$key" in
                    bind)
                        EXTRA_BINDS+=("--bind" "$local_path" "$local_path")
                        EXTRA_WRITE_PATHS+=("$local_path")
                        ;;
                    ro-bind) EXTRA_BINDS+=("--ro-bind" "$local_path" "$local_path") ;;
                esac
                ;;
            options)
                case "$key" in
                    ssh)       [[ "$value" == "true" ]] && BIND_SSH=true ;;
                    share-pid) [[ "$value" == "true" ]] && SHARE_PID=true ;;
                    block-env) BLOCK_ENV="$value" ;;
                esac
                ;;
        esac
    done < "$CONFIG_FILE"
fi

if [[ -n "$SHELL_MODE" ]]; then
    ENTRY_BIN="$(command -v "$SHELL_MODE" 2>/dev/null || true)"
    if [[ -z "$ENTRY_BIN" ]]; then
        echo "Error: $SHELL_MODE not found in PATH" >&2
        exit 1
    fi
    ENTRY_ARGS=()
else
    if [[ "$OS" == "Darwin" ]]; then
        ENTRY_BIN="$(command -v claude 2>/dev/null || true)"
    else
        ENTRY_BIN="$(readlink -f "$(command -v claude)" 2>/dev/null || true)"
    fi
    if [[ -z "$ENTRY_BIN" || ! -x "$ENTRY_BIN" ]]; then
        echo "Error: claude not found in PATH" >&2
        exit 1
    fi
    ENTRY_ARGS=(--dangerously-skip-permissions ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"})
fi

# ── macOS: Seatbelt sandbox ──────────────────────────────────────────────────
if [[ "$OS" == "Darwin" ]]; then
    # Build the seatbelt profile dynamically
    PROFILE='(version 1)
(allow default)

;; Deny all file writes globally
(deny file-write*)

;; Allow writes needed for process spawning (pipes, PTYs, sockets)
(allow file-write* (vnode-type FIFO))
(allow file-write* (vnode-type CHARACTER-DEVICE))
(allow file-write* (vnode-type SOCKET))

;; Allow writes to project directory
(allow file-write* (subpath "'"$PROJECT_DIR"'"))

;; Allow writes to Claude config
(allow file-write* (subpath "'"$HOME/.claude"'"))
(allow file-write* (literal "'"$HOME/.claude.json"'"))

;; Allow writes to temp directories
(allow file-write* (subpath "/private/tmp"))
(allow file-write* (subpath "/private/var/folders"))
(allow file-write* (subpath "/tmp"))
(allow file-write* (subpath "'"${TMPDIR:-/tmp}"'"))

;; Allow writes to nix store (for nix operations)
(allow file-write* (subpath "/nix"))

;; Allow writes to Keychain and security services (for OAuth token refresh)
(allow file-write* (subpath "'"$HOME/Library/Keychains"'"))
(allow file-write* (regex #"^/private/var/folders/.*/com\.apple\.security\."))
(allow file-write* (subpath "'"$HOME/Library/Preferences"'"))

;; Allow writes to Claude app data and cache (for token storage and refresh)
(allow file-write* (subpath "'"$HOME/Library/Application Support/Claude"'"))
(allow file-write* (subpath "'"$HOME/Library/Caches/claude-cli-nodejs"'"))
'

    # Extra write paths from --bind or .claudebox config
    for extra_path in "${EXTRA_WRITE_PATHS[@]+"${EXTRA_WRITE_PATHS[@]}"}"; do
        PROFILE+='(allow file-write* (subpath "'"$extra_path"'"))
'
    done

    # Block .env files
    if [[ -n "$BLOCK_ENV" ]]; then
        IFS=',' read -ra ENV_FILES <<<"$BLOCK_ENV"
        for env_file in "${ENV_FILES[@]}"; do
            env_path="$PROJECT_DIR/$env_file"
            if [[ -f "$env_path" ]]; then
                PROFILE+='(deny file-read* (literal "'"$env_path"'"))
'
            fi
        done
    fi

    cd "$PROJECT_DIR"
    exec sandbox-exec -p "$PROFILE" "$ENTRY_BIN" "${ENTRY_ARGS[@]}"
fi

# ── Linux: Bubblewrap sandbox ────────────────────────────────────────────────

# Build bwrap arguments — order matters: base mounts first, then overlays on top
BWRAP_ARGS=(
    # Sandbox essentials (must come first so later binds overlay correctly)
    --tmpfs /tmp
    --proc /proc
    --dev-bind /dev /dev
    --share-net
    --die-with-parent

    # System (read-only)
    --ro-bind /usr /usr
    --ro-bind /bin /bin
    --ro-bind /etc/resolv.conf /etc/resolv.conf
    --ro-bind /etc/hosts /etc/hosts
    --ro-bind /etc/ssl /etc/ssl
    --ro-bind /etc/passwd /etc/passwd
    --ro-bind /etc/group /etc/group
    --ro-bind /sys /sys
    --ro-bind /run /run
)

# PID namespace isolation (default: isolated, share-pid disables it)
if [[ "$SHARE_PID" != true ]]; then
    BWRAP_ARGS+=(--unshare-pid)
fi

# /lib and /lib64 may not exist on all systems
[[ -e /lib ]] && BWRAP_ARGS+=(--ro-bind /lib /lib)
[[ -e /lib64 ]] && BWRAP_ARGS+=(--ro-bind /lib64 /lib64)
[[ -e /sbin ]] && BWRAP_ARGS+=(--ro-bind /sbin /sbin)

# Nix store (read-only) - needed for nix-installed claude and tools
[[ -e /nix ]] && BWRAP_ARGS+=(--ro-bind /nix /nix)

# Home directory as tmpfs base so child bind mounts have a mountpoint
BWRAP_ARGS+=(--tmpfs "$HOME")

# Git config
[[ -f "$HOME/.gitconfig" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.gitconfig" "$HOME/.gitconfig")
[[ -d "$HOME/.config/git" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.config/git" "$HOME/.config/git")

# Nix profile symlinks (so nix-installed tools like pixi are on PATH)
[[ -e "$HOME/.nix-profile" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.nix-profile" "$HOME/.nix-profile")
[[ -d "$HOME/.local/state/nix" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.local/state/nix" "$HOME/.local/state/nix")

# Node/nvm (needed for claude's node runtime)
[[ -d "$HOME/.nvm" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.nvm" "$HOME/.nvm")
[[ -d "$HOME/.fnm" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.fnm" "$HOME/.fnm")
[[ -d "$HOME/.npm" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.npm" "$HOME/.npm")

# Claude native installer: launcher (~/.local/bin/claude) execs a versioned
# binary under ~/.local/share/claude/versions/*, so both must be visible inside
# the sandbox (the tmpfs $HOME above hides them otherwise).
[[ -e "$HOME/.local/bin/claude" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.local/bin/claude" "$HOME/.local/bin/claude")
[[ -d "$HOME/.local/share/claude" ]] && BWRAP_ARGS+=(--ro-bind "$HOME/.local/share/claude" "$HOME/.local/share/claude")

# Claude auth and config (read-write so sessions persist)
[[ -d "$HOME/.claude" ]] && BWRAP_ARGS+=(--bind "$HOME/.claude" "$HOME/.claude")
[[ -f "$HOME/.claude.json" ]] && BWRAP_ARGS+=(--bind "$HOME/.claude.json" "$HOME/.claude.json")

# SSH (optional)
if [[ "$BIND_SSH" == true ]] && [[ -d "$HOME/.ssh" ]]; then
    BWRAP_ARGS+=(--ro-bind "$HOME/.ssh" "$HOME/.ssh")
fi

# Project directory (read-write)
BWRAP_ARGS+=(
    --bind "$PROJECT_DIR" "$PROJECT_DIR"
    --chdir "$PROJECT_DIR"
)

# Extra user-specified bind mounts
if [[ ${#EXTRA_BINDS[@]} -gt 0 ]]; then
    BWRAP_ARGS+=("${EXTRA_BINDS[@]}")
fi

# Block .env files by overlaying with /dev/null
if [[ -n "$BLOCK_ENV" ]]; then
    IFS=',' read -ra ENV_FILES <<<"$BLOCK_ENV"
    for env_file in "${ENV_FILES[@]}"; do
        env_path="$PROJECT_DIR/$env_file"
        if [[ -f "$env_path" ]]; then
            BWRAP_ARGS+=(--ro-bind /dev/null "$env_path")
        fi
    done
fi

exec bwrap "${BWRAP_ARGS[@]}" "$ENTRY_BIN" "${ENTRY_ARGS[@]}"
