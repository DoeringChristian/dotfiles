common/.local/bin/ filter=lfs diff=lfs merge=lfs -text

# fonts (large binaries) tracked via LFS; identical blobs across paths dedupe
*.ttf filter=lfs diff=lfs merge=lfs -text

# pixi: treat the lock as generated, avoid 3-way merges
pixi.lock merge=binary linguist-language=YAML linguist-generated=true -diff
