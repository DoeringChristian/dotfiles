#!/usr/bin/env python3
"""A minimal custom pixi build backend for npm CLI tools.

It speaks pixi's build-backend protocol (JSON-RPC 2.0 over newline-delimited
stdio, Pixi Build API v4) and turns a `[package]` whose build config names an
npm package into a conda package, by generating a one-line rattler-build recipe
(`npm install -g ... --prefix $PREFIX`) and shelling out to `rattler-build`.

This is a dev-grade backend: it's run via PIXI_BUILD_BACKEND_OVERRIDE rather
than published to a channel. stdout carries ONLY JSON-RPC; all logs go to stderr
(pixi surfaces stderr as build output).

Consumer manifest (ext/<tool>/pixi.toml):

    [package]
    name = "gemini-cli"
    version = "0.47.0"
    [package.build.backend]
    name = "pixi-build-npm"
    version = "*"
    [package.build.config]
    npm-package = "@google/gemini-cli"   # required: the npm package name
    node = ">=20"                         # optional: node version spec
    # npm-version defaults to the [package] version
"""
import sys
import os
import json
import shutil
import subprocess
import glob

STATE = {}


def log(*a):
    print("[pixi-build-npm]", *a, file=sys.stderr, flush=True)


def find_rattler_build():
    cand = os.environ.get("RATTLER_BUILD") or shutil.which("rattler-build")
    if cand and os.path.exists(cand):
        return cand
    home = os.path.expanduser("~/.pixi/bin/rattler-build")
    if os.path.exists(home):
        return home
    raise RuntimeError(
        "rattler-build not found on PATH (install it: `pixi global install rattler-build`)"
    )


def node_spec():
    return STATE["config"].get("node", ">=18")


def pkg_identity(output=None):
    pm = STATE.get("project_model") or {}
    cfg = STATE.get("config") or {}
    name = (output or {}).get("name") or pm.get("name") or cfg.get("name")
    version = (
        (output or {}).get("version")
        or pm.get("version")
        or cfg.get("npm-version")
    )
    return name, str(version)


# ---- protocol methods ------------------------------------------------------

def negotiate_capabilities(params):
    return {"capabilities": {"providesCondaOutputs": True, "providesCondaBuildV1": True}}


def initialize(params):
    STATE["manifest_path"] = params.get("manifestPath")
    STATE["project_model"] = params.get("projectModel") or {}
    STATE["config"] = params.get("configuration") or {}
    log("initialized for", STATE["project_model"].get("name"))
    return {}


def conda_outputs(params):
    subdir = params["hostPlatform"]
    pm = STATE.get("project_model") or {}
    name, version = pkg_identity()
    nodedep = [{"name": "nodejs", "binary": {"version": node_spec()}}]
    output = {
        "metadata": {
            "name": name,
            "version": version,
            "build": "0",
            "buildNumber": 0,
            "subdir": subdir,
            "license": pm.get("license"),
            "licenseFamily": None,
            "noarch": False,            # platform-specific (npm pkgs may carry native bits)
            "purls": None,
            "pythonSitePackagesPath": None,
            "variant": {},
        },
        # rattler-build provides node at build time from the generated recipe,
        # so we don't ask pixi to set up a build prefix.
        "buildDependencies": None,
        "hostDependencies": None,
        "runDependencies": {"depends": nodedep, "constraints": []},
        "ignoreRunExports": {"byName": [], "fromPackage": []},
        "runExports": {
            "weak": [], "strong": [], "noarch": [],
            "weakConstrains": [], "strongConstrains": [],
        },
        "inputGlobs": None,
    }
    return {"outputs": [output], "inputGlobs": []}


def conda_build_v1(params):
    output = params["output"]
    subdir = output["subdir"]
    name, version = pkg_identity(output)
    cfg = STATE.get("config") or {}
    npm_package = cfg.get("npm-package")
    if not npm_package:
        raise RuntimeError("config is missing required key `npm-package`")
    npm_version = cfg.get("npm-version", version)

    work = params["workDirectory"]
    out_dir = params.get("outputDirectory") or os.path.join(work, "output")
    recipe_dir = os.path.join(work, "recipe")
    os.makedirs(recipe_dir, exist_ok=True)
    os.makedirs(out_dir, exist_ok=True)

    recipe = {
        "package": {"name": name, "version": version},
        "build": {
            "number": 0,
            "string": "0",
            "script": [
                'npm install -g "%s@%s" --prefix "$PREFIX"' % (npm_package, npm_version),
            ],
        },
        "requirements": {
            "build": ["nodejs %s" % node_spec()],
            "run": ["nodejs %s" % node_spec()],
        },
    }
    recipe_path = os.path.join(recipe_dir, "recipe.yaml")
    with open(recipe_path, "w") as f:
        json.dump(recipe, f)   # YAML is a superset of JSON; rattler-build accepts it

    channels = params.get("channels") or ["https://prefix.dev/conda-forge"]
    cmd = [find_rattler_build(), "build",
           "--recipe", recipe_path,
           "--output-dir", out_dir,
           "--target-platform", subdir,
           "--test", "skip"]
    for ch in channels:
        cmd += ["--channel", str(ch)]
    log("running:", " ".join(cmd))
    subprocess.run(cmd, check=True, stdout=sys.stderr, stderr=sys.stderr)

    matches = glob.glob(os.path.join(out_dir, subdir, "%s-%s-*.conda" % (name, version)))
    if not matches:
        raise RuntimeError("no .conda produced in %s/%s" % (out_dir, subdir))
    conda_file = matches[0]
    log("built", conda_file)
    build_str = os.path.basename(conda_file).rsplit("-", 1)[-1][:-len(".conda")]
    return {
        "output_file": conda_file,
        "input_globs": [],
        "name": name,
        "version": version,
        "build": build_str,
        "subdir": subdir,
    }


HANDLERS = {
    "negotiateCapabilities": negotiate_capabilities,
    "initialize": initialize,
    "conda/outputs": conda_outputs,
    "conda/build_v1": conda_build_v1,
}


def main():
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            req = json.loads(line)
        except Exception as e:
            log("bad json:", e)
            continue
        msg_id = req.get("id")
        method = req.get("method")
        if method is None:          # a response/notification we don't care about
            continue
        log("->", method)
        handler = HANDLERS.get(method)
        try:
            if handler is None:
                raise RuntimeError("unknown method: %s" % method)
            result = handler(req.get("params") or {})
            resp = {"jsonrpc": "2.0", "id": msg_id, "result": result}
        except Exception as e:
            import traceback
            log("ERROR in", method, ":", e)
            log(traceback.format_exc())
            resp = {"jsonrpc": "2.0", "id": msg_id,
                    "error": {"code": -32000, "message": str(e)}}
        if msg_id is not None:
            sys.stdout.write(json.dumps(resp) + "\n")
            sys.stdout.flush()


if __name__ == "__main__":
    main()
