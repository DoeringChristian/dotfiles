{
  "$schema": "https://schemas.conda.org/menuinst-1-2-0.schema.json",
  "menu_name": "tev",
  "menu_items": [
    {
      "name": "tev",
      "description": "The EDR Viewer -- a high dynamic range (HDR) image viewer",
      "icon": "{{ MENU_DIR }}/tev.icns",
      "command": ["{{ PREFIX }}/bin/tev", "$@"],
      "platforms": {
        "osx": {
          "CFBundleName": "tev",
          "CFBundleDisplayName": "tev",
          "CFBundleIdentifier": "de.tom94.tev",
          "CFBundleDocumentTypes": [
            {
              "CFBundleTypeName": "Image",
              "LSHandlerRank": "Alternate",
              "LSItemContentTypes": [
                "public.image", "com.ilm.openexr-image", "public.radiance"
              ]
            }
          ]
        },
        "linux": {
          "Categories": ["Graphics", "Photography", "Viewer"],
          "MimeType": [
            "image/jpeg", "image/png", "image/gif", "image/bmp", "image/tiff",
            "image/webp", "image/x-exr", "image/x-hdr"
          ]
        }
      }
    }
  ]
}
